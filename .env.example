# MEGA REAPER 9000 — Environment Config
# Copy to .env and fill in values. Never commit .env.

# Flask secret key — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Admin credentials
# Set username
REAPER_USER=admin
# Generate hash with: python3 scripts/hash_password.py yourpassword
REAPER_PASSWORD_HASH=

# Optional: override default SQLite path
# DATABASE_URL=sqlite:///data/reaper.db

# Metasploit RPC (msfrpcd)
# Start with: msfrpcd -P yourpassword -S (on Kali or Metasploit host)
MSF_HOST=127.0.0.1
MSF_PORT=55553
MSF_PASSWORD=
MSF_SSL=true
